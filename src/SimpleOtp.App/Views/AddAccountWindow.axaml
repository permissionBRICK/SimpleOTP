<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleOtp.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="640"
        xmlns:conv="using:SimpleOtp.App.Converters"
        x:Class="SimpleOtp.App.Views.AddAccountWindow"
        x:DataType="vm:AddAccountViewModel"
        Width="420" Height="660"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        Background="#16171A"
        DragDrop.AllowDrop="True"
        Title="Add account">

    <Window.Resources>
        <conv:BoolToErrorBrushConverter x:Key="ErrorBrush"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="#8A8F99"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
        <Style Selector="TextBlock.field">
            <Setter Property="Foreground" Value="#C9CDD4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3D7DEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4F8BF5"/>
        </Style>
    </Window.Styles>

    <DockPanel Margin="18">
        <!-- Action buttons pinned to the bottom -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="0,14,0,0">
            <TextBlock Grid.Column="0" Text="🔒 Sealed to this device's TPM" Foreground="#6F757F"
                       FontSize="11" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Cancel" MinWidth="84" Margin="0,0,10,0"
                    HorizontalContentAlignment="Center" Click="OnCancel"/>
            <Button Grid.Column="2" Classes="primary" Content="{Binding AddButtonText}" MinWidth="84"
                    HorizontalContentAlignment="Center" Click="OnAdd"/>
        </Grid>

        <ScrollViewer>
            <StackPanel Spacing="2">
                <TextBlock Text="Add account" FontSize="20" FontWeight="Bold" Foreground="#F2F3F5"/>

                <TextBlock Classes="section" Text="PASTE A LINK OR SECRET"/>
                <TextBox Text="{Binding PasteInput}" AcceptsReturn="True" Height="64"
                         TextWrapping="Wrap" PlaceholderText="otpauth://totp/...  or a Base32 secret"/>
                <Button Content="Load" HorizontalAlignment="Left" Margin="0,6,0,0"
                        Command="{Binding LoadFromPasteCommand}"/>

                <TextBlock Classes="section" Text="IMPORT A QR SCREENSHOT"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="📂 Open image…" Click="OnOpenImage"/>
                    <Button Content="📋 Paste image" Click="OnPasteImage"/>
                </StackPanel>
                <TextBlock Text="…or drag an image file onto this window. A Google Authenticator export QR imports many accounts at once."
                           Foreground="#6F757F" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>

                <!-- Single-account details (hidden during a bulk export import) -->
                <StackPanel IsVisible="{Binding !IsBulk}">
                    <TextBlock Classes="section" Text="DETAILS"/>
                    <TextBlock Classes="field" Text="Issuer (service)"/>
                    <TextBox Text="{Binding Issuer}" PlaceholderText="e.g. GitHub"/>
                    <TextBlock Classes="field" Text="Label (account)"/>
                    <TextBox Text="{Binding Label}" PlaceholderText="e.g. alice@example.com"/>
                    <TextBlock Classes="field" Text="Secret (Base32)"/>
                    <TextBox Text="{Binding Secret}" FontFamily="Cascadia Code,Consolas,monospace"
                             PlaceholderText="JBSWY3DPEHPK3PXP"/>

                    <Grid ColumnDefinitions="*,*,*" Margin="0,6,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Classes="field" Text="Algorithm"/>
                            <ComboBox ItemsSource="{Binding Algorithms}" SelectedIndex="{Binding SelectedAlgorithmIndex}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="3,0">
                            <TextBlock Classes="field" Text="Digits"/>
                            <TextBox Text="{Binding Digits}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0,0,0">
                            <TextBlock Classes="field" Text="Period (s)"/>
                            <TextBox Text="{Binding Period}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Bulk import preview (Google Authenticator export, possibly multiple QR parts) -->
                <StackPanel IsVisible="{Binding IsBulk}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Classes="section" Text="ACCOUNTS IN THIS EXPORT"/>
                        <Button Grid.Column="1" Content="Clear" FontSize="11" Padding="8,2"
                                Command="{Binding ClearBulkCommand}"/>
                    </Grid>
                    <Border Background="#1B1D21" CornerRadius="6" Padding="6" MaxHeight="280">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding BulkItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MigrationItemViewModel">
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="2,1" Foreground="#C9CDD4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" Foreground="#E7E9EC"/>
                                                <TextBlock Text="{Binding Detail}" Foreground="#8A8F99" FontSize="11"
                                                           IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <Border Margin="0,12,0,0" IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#20242A" CornerRadius="6" Padding="10,8">
                    <TextBlock Text="{Binding Status}" TextWrapping="Wrap"
                               Foreground="{Binding IsError, Converter={StaticResource ErrorBrush}}"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
