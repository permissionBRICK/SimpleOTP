<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SimpleOtp.App.ViewModels"
        xmlns:conv="using:SimpleOtp.App.Converters"
        xmlns:shapes="using:Avalonia.Controls.Shapes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="640"
        x:Class="SimpleOtp.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Width="400" Height="640" MinWidth="360" MinHeight="480"
        Icon="/Assets/avalonia-logo.ico"
        RequestedThemeVariant="Dark"
        Background="#16171A"
        Title="SimpleOTP">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:ProgressToSweepConverter x:Key="ProgressToSweep"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9CDD4"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2C31"/>
        </Style>

        <Style Selector="Button.card">
            <Setter Property="Background" Value="#212329"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.card:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#272A31"/>
        </Style>

        <Style Selector="TextBlock.code">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Menlo,monospace"/>
            <Setter Property="Foreground" Value="#6AA9FF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="TextBlock.code.expiring">
            <Setter Property="Foreground" Value="#F2A33C"/>
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#3D7DEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4F8BF5"/>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- ===== Main vertical layout ===== -->
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Padding="16,12" Background="#1B1D21">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="SimpleOTP" FontSize="18" FontWeight="Bold"
                               Foreground="#F2F3F5" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Classes="icon" Content="🔒" ToolTip.Tip="Lock"
                            IsVisible="{Binding IsReady}" Click="OnLockClick"/>
                    <Button Grid.Column="3" Classes="icon" Content="⚙" ToolTip.Tip="Settings"
                            IsVisible="{Binding IsReady}" Click="OnSettingsClick"/>
                    <Button Grid.Column="4" Classes="icon" Content="+" FontSize="24" FontWeight="Bold"
                            ToolTip.Tip="Add account" IsVisible="{Binding IsReady}" Click="OnAddClick"/>
                </Grid>
            </Border>

            <Panel>
                <!-- READY: token list -->
                <Grid IsVisible="{Binding IsReady}" Margin="14,14,14,0">
                    <ScrollViewer IsVisible="{Binding HasAccounts}">
                        <ItemsControl ItemsSource="{Binding Tokens}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AccountItemViewModel">
                                    <Button Classes="card" Click="OnCardClick">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Title}" FontSize="14"
                                                           FontWeight="SemiBold" Foreground="#E7E9EC"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="12"
                                                           Foreground="#8A8F99"
                                                           IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Code}" Classes="code"
                                                           Classes.expiring="{Binding IsExpiring}" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- Ring countdown -->
                                            <Grid Grid.Column="1" Width="44" Height="44" VerticalAlignment="Center" Margin="8,0">
                                                <Ellipse Width="40" Height="40" Stroke="#33363D" StrokeThickness="4"/>
                                                <shapes:Arc Width="40" Height="40" StrokeThickness="4"
                                                            Stroke="#6AA9FF" StartAngle="-90"
                                                            SweepAngle="{Binding Progress, Converter={StaticResource ProgressToSweep}}"/>
                                                <TextBlock Text="{Binding SecondsRemaining}" FontSize="12"
                                                           Foreground="#C9CDD4" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <Button Grid.Column="2" Classes="icon" Content="🗑" FontSize="14"
                                                    ToolTip.Tip="Remove" VerticalAlignment="Center"
                                                    Click="OnDeleteClick"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <StackPanel IsVisible="{Binding !HasAccounts}" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Spacing="10" Margin="24">
                        <TextBlock Text="🔐" FontSize="44" HorizontalAlignment="Center"/>
                        <TextBlock Text="No accounts yet" FontSize="18" FontWeight="SemiBold"
                                   Foreground="#E7E9EC" HorizontalAlignment="Center"/>
                        <TextBlock Text="Add a token by pasting an otpauth:// link, importing a QR screenshot, or entering a secret."
                                   Foreground="#8A8F99" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="280"/>
                        <Button Classes="primary" Content="+  Add account" HorizontalAlignment="Center"
                                Margin="0,6,0,0" Click="OnAddClick"/>
                    </StackPanel>
                </Grid>

                <!-- LOCKED: unlock with PIN -->
                <StackPanel IsVisible="{Binding IsLocked}" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Spacing="12" Margin="32" MaxWidth="300">
                    <TextBlock Text="🔒" FontSize="44" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enter your PIN" FontSize="18" FontWeight="SemiBold"
                               Foreground="#E7E9EC" HorizontalAlignment="Center"/>
                    <TextBox Watermark="PIN" PasswordChar="•" Text="{Binding UnlockPin}"
                             HorizontalAlignment="Stretch" KeyDown="OnPinKeyDown"/>
                    <TextBlock Text="{Binding UnlockError}" Foreground="#F2685C"
                               IsVisible="{Binding UnlockError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    <Button Classes="primary" Content="Unlock" Command="{Binding UnlockCommand}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <Button Content="Retry auto-unlock" Command="{Binding RetryAutoUnlockCommand}"
                            IsVisible="{Binding AutoUnlockAvailable}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- CONNECTING: trying network auto-unlock -->
                <StackPanel IsVisible="{Binding IsConnecting}" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Spacing="12" Margin="32">
                    <TextBlock Text="🌐" FontSize="44" HorizontalAlignment="Center"/>
                    <TextBlock Text="Unlocking…" FontSize="16" Foreground="#C9CDD4" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- NO TPM -->
                <StackPanel IsVisible="{Binding IsNoTpm}" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Spacing="12" Margin="32" MaxWidth="320">
                    <TextBlock Text="🛡" FontSize="44" HorizontalAlignment="Center"/>
                    <TextBlock Text="No TPM detected" FontSize="18" FontWeight="SemiBold"
                               Foreground="#E7E9EC" HorizontalAlignment="Center"/>
                    <TextBlock Foreground="#A7ABB3" TextWrapping="Wrap" TextAlignment="Center"
                               Text="SimpleOTP stores your secrets sealed to this device's TPM 2.0 chip. No usable TPM was found, so it can't run here. Enable the TPM in your firmware/BIOS (or VM settings) and try again."/>
                </StackPanel>

                <!-- ERROR -->
                <StackPanel IsVisible="{Binding IsError}" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Spacing="12" Margin="32" MaxWidth="320">
                    <TextBlock Text="⚠" FontSize="44" HorizontalAlignment="Center"/>
                    <TextBlock Text="Couldn't open the vault" FontSize="18" FontWeight="SemiBold"
                               Foreground="#E7E9EC" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#A7ABB3" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>
            </Panel>
        </DockPanel>

        <!-- Toast overlay -->
        <Border IsVisible="{Binding IsToastVisible}" Background="#E6262A31" CornerRadius="10"
                Padding="18,10" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,28" BorderBrush="#3A3D44" BorderThickness="1">
            <TextBlock Text="{Binding ToastText}" Foreground="#F2F3F5" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
